---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Bioclimatic Pergola Marbella",
  "description": "Motorised aluminium bioclimatic pergolas with adjustable louvres supplied and installed in Marbella by Costa Glass.",
  "provider": { "@type": "LocalBusiness", "name": "Costa Glass", "url": "https://costaglass.com" },
  "areaServed": { "@type": "City", "name": "Marbella" },
  "url": "https://costaglass.com/en/bioclimatic-pergola-marbella/"
});
