---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Glass Curtains Costa del Sol",
  "description": "Frameless glass curtain systems supplied and installed across the entire Costa del Sol by Costa Glass.",
  "provider": { "@type": "LocalBusiness", "name": "Costa Glass", "url": "https://costaglass.com" },
  "areaServed": { "@type": "Place", "name": "Costa del Sol" },
  "url": "https://costaglass.com/en/glass-curtains-costa-del-sol/"
});
---

<BaseLayout
  title="Glass Curtains Costa del Sol | Frameless Glazing Specialists | Costa Glass"
  description="Glass curtains across the Costa del Sol — Marbella, Estepona, Benalmádena, Fuengirola, Torremolinos and Nerja. Frameless frameless systems by Costa Glass manufacturers."
  canonical="https://costaglass.com/en/glass-curtains-costa-del-sol/"
  ogImage="https://costaglass.com/Assets/products/glass curtain walls/c3.jpg"
  pageSchema={pageSchema}
  lang="en"
>

<style>
  .en-hero { background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 100%); color: white; padding: 100px 20px 80px; text-align: center; }
  .en-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); margin: 0 0 20px; font-family: 'Playfair Display', serif; }
  .en-hero p { font-size: 1.2rem; max-width: 650px; margin: 0 auto 32px; opacity: 0.9; }
  .en-badge { display: inline-block; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 30px; padding: 6px 20px; font-size: 0.875rem; margin-bottom: 20px; }
  .en-section { padding: 70px 20px; }
  .en-section:nth-child(even) { background: #f8fafc; }
  .en-container { max-width: 900px; margin: 0 auto; }
  .en-section h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); color: #0f172a; margin: 0 0 24px; font-family: 'Playfair Display', serif; }
  .en-section p { font-size: 1.05rem; line-height: 1.8; color: #374151; margin: 0 0 18px; }
  .en-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin: 30px 0; }
  .en-card { background: white; border-radius: 12px; padding: 20px; border: 1px solid #e2e8f0; }
  .en-card h3 { font-size: 1rem; color: #0f172a; margin: 0 0 8px; font-weight: 700; }
  .en-card p { font-size: 0.9rem; color: #475569; margin: 0; }
  .coverage-list { list-style: none; padding: 0; margin: 20px 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; }
  .coverage-list li { background: white; border: 1px solid #bae6fd; border-radius: 8px; padding: 10px 16px; color: #0369a1; font-weight: 600; font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
  .cta-band { background: linear-gradient(135deg, #0284c7, #0ea5e9); color: white; padding: 60px 20px; text-align: center; }
  .cta-band h2 { font-size: 2rem; margin: 0 0 16px; }
  .cta-band p { font-size: 1.1rem; margin: 0 0 28px; opacity: 0.95; max-width: 560px; margin-left: auto; margin-right: auto; }
  .btn-white { display: inline-block; background: white; color: #0284c7; padding: 14px 32px; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 1rem; }
  .btn-white:hover { background: #f0f9ff; }
  .related-links { list-style: none; padding: 0; margin: 20px 0 0; display: flex; flex-wrap: wrap; gap: 12px; }
  .related-links a { display: inline-block; background: #e0f2fe; color: #0284c7; padding: 8px 18px; border-radius: 6px; text-decoration: none; font-size: 0.9rem; font-weight: 500; }
  .compare-table { width: 100%; border-collapse: collapse; margin: 24px 0; }
  .compare-table th { background: #0f172a; color: white; padding: 12px 16px; text-align: left; font-size: 0.9rem; }
  .compare-table td { padding: 12px 16px; border-bottom: 1px solid #e2e8f0; font-size: 0.95rem; color: #374151; }
  .compare-table tr:nth-child(even) td { background: #f8fafc; }
</style>

