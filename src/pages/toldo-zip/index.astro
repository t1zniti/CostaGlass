---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToldoZipContent from '../../components/products/ToldoZipContent.astro';

const pageSchema = JSON.stringify([{
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Toldos Zip y Estores Exteriores Motorizados",
      "description": "Toldos verticales con guías zip y tejido Screen microperforado. Sistema de cerramiento textil motorizado para terrazas, pérgolas bioclimáticas y fachadas. Resistencia al viento de hasta 150 km/h. Instalación a medida en la Costa del Sol.",
      "brand": { "@type": "Brand", "name": "Costa Glass" },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://costaglass.es/toldo-zip/"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "78"
      }
    },{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué diferencia hay entre un toldo vertical normal y un Toldo Zip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Un toldo normal (guiado por cable o caída libre) se mueve con el viento y deja huecos laterales. El sistema ZIP termoselda una cremallera a la tela que encaja en las guías, logrando tensión perfecta, sellado total contra insectos y resistencia a vientos huracanados."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se pierde la vista al exterior con un Toldo Zip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Utilizamos tejidos técnicos tipo «Screen» microperforados que filtran el sol y el calor, pero permiten ver perfectamente el paisaje desde el interior hacia el exterior."
          }
        },
        {
          "@type": "Question",
          "name": "¿Dónde se pueden instalar los Toldos Zip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Son extremadamente versátiles. Se instalan entre paredes, en fachadas, terrazas, grandes ventanales y son el complemento perfecto para cerrar los laterales de Pérgolas Bioclimáticas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto aguanta el viento un Toldo Zip?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El sistema Zip está diseñado para resistir rachas de hasta 150 km/h. La cremallera lateral que ancla el tejido a las guías de aluminio impide que la tela aletee, se deforme o salga de los carriles — incluso en episodios de viento de Levante intenso característicos de la Costa del Sol."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se puede motorizar el Toldo Zip y conectarlo a la domótica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Todos nuestros toldos zip se pueden motorizar con motores tubulares de bajo consumo controlados por mando a distancia, app móvil o integrados en sistemas de domótica (KNX, Somfy, Zigbee). También es posible añadir sensores de viento y sol que recogen y despliegan el toldo automáticamente."
          }
        },
        {
          "@type": "Question",
          "name": "¿El Toldo Zip actúa como mosquitera?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Cuando está completamente bajado, la cremallera lateral sella los cantos laterales de la tela contra las guías de aluminio, eliminando los huecos que tienen los toldos convencionales. Esto convierte la pantalla en una barrera total contra insectos — una mosquitera de gran formato, de alto rendimiento y con estética premium."
          }
        }
      ]
    }]);
---

<BaseLayout
  title="Toldos Zip y Estores Exteriores Motorizados | Costa Glass"
  description="Toldos zip y screen exteriores motorizados para terrazas, pérgolas y fachadas en la Costa del Sol. Toldos verticales con guías zip que resisten vientos de hasta 150 km/h. Instalación rápida y presupuesto en 24h."
  canonical="https://costaglass.es/toldo-zip/"
  pageSchema={pageSchema}
>
  <ToldoZipContent />
</BaseLayout>
