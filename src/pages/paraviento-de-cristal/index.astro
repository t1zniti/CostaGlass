---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ParavientoDeCristalContent from '../../components/products/ParavientoDeCristalContent.astro';

const pageSchema = JSON.stringify([{
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Paravientos de Cristal Extensibles",
      "description": "Mamparas cortavientos de cristal templado o laminado con sistema telescópico regulable en altura. Instalación sin obra mayor, base autoportante o anclada al suelo. Ideales para terrazas de restaurantes, zonas de piscina y patios privados en la Costa del Sol.",
      "brand": { "@type": "Brand", "name": "Costa Glass" },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://costaglass.es/paraviento-de-cristal/"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "96"
      }
    },{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Los paravientos de cristal resisten rachas de viento fuertes o temporales?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Los perfiles estructurales de aluminio y el vidrio de seguridad están específicamente diseñados para soportar grandes cargas de viento en primera línea de playa. Todos los sistemas de Costa Glass se dimensionan según la zona climática de la Costa del Sol, teniendo en cuenta el viento de Levante y las rachas costeras. El cristal templado o laminado cumple la normativa europea EN 12150 y EN 14449."
          }
        },
        {
          "@type": "Question",
          "name": "¿Necesito licencia de obras para instalar paravientos de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En general, no. Al ser elementos modulares que no incorporan techo ni modifican la estructura del edificio, la mayoría de los ayuntamientos los clasifican como elementos desmontables o mobiliario exterior. Esto los convierte en la solución perfecta para hostelería en municipios con normativa municipal estricta, como Marbella o Estepona, donde otras obras requieren licencias complejas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se pueden personalizar los paravientos de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, completamente. El color del perfil de aluminio se puede seleccionar de la carta RAL para integrarse con cualquier proyecto arquitectónico. El tipo de vidrio también es configurable: transparente para máximas vistas, translúcido o satinado para más privacidad, o con vinilo personalizado con el logotipo del negocio. También es posible integrar jardineras en la base para un acabado más natural."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué significa que el sistema sea extensible o telescópico?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El panel superior de cristal puede deslizarse hacia arriba o hacia abajo dentro del perfil de aluminio, permitiendo regular la altura de protección en función del viento y las condiciones del momento. En días calmados se puede bajar para maximizar la apertura y la ventilación; cuando arrecia el viento, el panel sube en segundos y ofrece una barrera sólida sin necesidad de herramientas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tarda la instalación de paravientos de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La mayoría de proyectos residenciales y de hostelería de tamaño estándar se instalan en 1 día sin obra civil significativa. Los sistemas con base autoportante o jardinera no requieren ni siquiera taladrar el suelo. Nuestro equipo realiza la toma de medidas, fabricación a medida y montaje optimizando los tiempos para no interrumpir el negocio ni la vida cotidiana."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué mantenimiento necesitan los paravientos de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Mínimo. Los perfiles de aluminio anodizado son resistentes a la corrosión salina, especialmente importantes en entornos costeros. El mantenimiento se limita a la limpieza periódica del vidrio con agua y jabón neutro y una revisión anual de los anclajes y el sistema telescópico. Costa Glass ofrece servicio postventa con garantía de 5 años en todos sus sistemas."
          }
        }
      ]
    }]);
---

<BaseLayout
  title="Paravientos de Cristal para Terrazas y Hostelería | Costa Glass"
  description="Paravientos de cristal extensibles y regulables en altura para terrazas, restaurantes y zonas de piscina en la Costa del Sol. Cerramientos cortavientos sin obra, con vidrio templado de seguridad. Presupuesto gratuito en 24h."
  canonical="https://costaglass.es/paraviento-de-cristal/"
  pageSchema={pageSchema}
>
  <ParavientoDeCristalContent />
</BaseLayout>
