---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CortinasDeCristalContent from '../../components/products/CortinasDeCristalContent.astro';

const pageSchema = JSON.stringify([{
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Cortinas de Cristal Sin Perfiles",
      "description": "Sistema de acristalamiento sin perfiles verticales para terrazas, balcones y porches. Paneles de cristal templado abatibles o correderos con máxima transparencia.",
      "brand": { "@type": "Brand", "name": "Costa Glass" },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://costaglass.com/cortinas-de-cristal/"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "127"
      }
    },{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Necesito permiso de la comunidad para instalar cortinas de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "En la mayoría de los casos, sí. Según la Ley de Propiedad Horizontal (LPH), cualquier modificación que altere la fachada del edificio requiere la aprobación de la junta de propietarios (generalmente mayoría de 3/5). Las cortinas de cristal sin perfiles son las que menos impacto visual generan, lo que facilita la aprobación. En Costa Glass te asesoramos con toda la documentación necesaria."
          }
        },
        {
          "@type": "Question",
          "name": "¿Las cortinas de cristal producen efecto invernadero en verano?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No si se instalan correctamente. Nuestros sistemas permiten la apertura total de los paneles, creando una ventilación del 90%. Además, ofrecemos vidrio de control solar que reduce la transmisión de calor hasta un 60%, manteniendo el espacio fresco incluso en los meses más calurosos de la Costa del Sol."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tarda la instalación de cortinas de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La instalación típica de una terraza estándar (10-15 m²) se completa en un solo día. No requiere obra civil, ni escombros, ni permisos de obra. Nuestro equipo realiza la toma de medidas, fabricación a medida y montaje profesional con mínima molestia."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuál es la diferencia entre cortinas de cristal correderas y abatibles?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Las cortinas abatibles se pliegan en acordeón hacia un lateral, permitiendo una apertura casi total del hueco. Las correderas se deslizan sobre raíles paralelos. Las abatibles son ideales para terrazas donde se desea máxima apertura; las correderas para espacios donde se prefiere apertura parcial y selectiva."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué mantenimiento necesitan las cortinas de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Prácticamente ninguno. Solo requieren limpieza periódica del cristal con agua y jabón neutro. Gracias al sistema de plegado, se puede acceder a la cara exterior de los paneles desde el interior, eliminando la necesidad de limpiar desde fuera en pisos altos."
          }
        }
      ]
    }]);
---

<BaseLayout
  title="Cortinas de Cristal Sin Perfiles | Acristalamiento de Terrazas — Costa Glass"
  description="Cortinas de cristal sin perfiles para terrazas y porches en la Costa del Sol. Fabricamos e instalamos cerramientos abatibles y correderos con garantía de 10 años. Presupuesto gratuito en 24h."
  canonical="https://costaglass.com/cortinas-de-cristal/"
  pageSchema={pageSchema}
>
  <CortinasDeCristalContent />
</BaseLayout>
