---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GuillotinaDeCristalContent from '../../components/products/GuillotinaDeCristalContent.astro';

const pageSchema = JSON.stringify([{
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Guillotinas de Cristal Motorizadas",
      "description": "Sistema de cerramiento vertical motorizado con cristal templado de seguridad. Control remoto, perfiles de aluminio minimalistas y máximo aislamiento térmico y acústico para terrazas, balcones y hostelería.",
      "brand": { "@type": "Brand", "name": "Costa Glass" },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://costaglass.es/guillotina-de-cristal/"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "84"
      }
    },{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Qué es una guillotina de cristal motorizada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Una guillotina de cristal motorizada es un sistema de cerramiento en el que los paneles de vidrio templado se deslizan verticalmente — hacia arriba o hacia abajo — mediante un motor eléctrico silencioso. A diferencia de las cortinas de cristal, los paneles no se pliegan lateralmente sino que suben y bajan. Esto las convierte en la opción ideal para fachadas, restaurantes con terrazas y espacios donde se requiere máxima apertura panorámica sin obstrukción visual."
          }
        },
        {
          "@type": "Question",
          "name": "¿Necesito instalación eléctrica especial para la motorización?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. El sistema motorizado de Costa Glass funciona con corriente estándar (230V). La instalación eléctrica se integra discretamente en el perfil superior o en la pared perimetral. También ofrecemos opciones con batería de respaldo para garantizar el funcionamiento en caso de corte de luz."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto tiempo dura la instalación de una guillotina de cristal?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La instalación media de una terraza o fachada de hostelería de tamaño estándar se completa en 1 a 2 días. No requiere obra civil significativa. Nuestro equipo realiza la toma de medidas, fabricación personalizada y montaje en el mínimo tiempo posible para no interrumpir tu actividad comercial o doméstica."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se puede controlar la guillotina desde el móvil?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Nuestros sistemas pueden integrarse con domótica (KNX, Zigbee) y controlarse mediante aplicación móvil, además del mando a distancia estándar. También es posible programar horarios automáticos de apertura y cierre, por ejemplo para restaurantes con horarios fijos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué grosor de cristal se usa en las guillotinas de Costa Glass?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Utilizamos vidrio templado de seguridad de 8 mm en aplicaciones residenciales estándar y 10-12 mm para proyectos de hostelería o grandes vanos. Todo el vidrio cumple con la normativa europea EN 12150 y supera los requisitos de resistencia al viento de la zona climática de Málaga y la Costa del Sol."
          }
        },
        {
          "@type": "Question",
          "name": "¿Las guillotinas de cristal necesitan mucho mantenimiento?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. El mantenimiento se reduce a una revisión anual del motor y los guías laterales, más la limpieza periódica del vidrio con agua y jabón neutro. Los perfiles de aluminio anodizado y el acero inoxidable de los herrajes son resistentes a la corrosión, especialmente en entornos costeros salinos como la Costa del Sol."
          }
        }
      ]
    }]);
---

<BaseLayout
  title="Guillotinas de Cristal Motorizadas | Cerramientos Verticales — Costa Glass"
  description="Guillotinas de cristal motorizadas para terrazas, balcones y restaurantes en la Costa del Sol. Sistema KG-70 con control remoto, vidrio templado y máximo aislamiento. Presupuesto gratuito en 24h."
  canonical="https://costaglass.es/guillotina-de-cristal/"
  pageSchema={pageSchema}
>
  <GuillotinaDeCristalContent />
</BaseLayout>
