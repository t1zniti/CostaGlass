---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RetractablePvcRoofContent from '../../components/products/RetractablePvcRoofContent.astro';

const pageSchema = JSON.stringify([{
      "@context": "https://schema.org",
      "@type": "Product",
      "name": "Pérgolas Retráctiles Motorizadas a Medida",
      "description": "Pérgolas de aluminio plegables con techo de lona tensada de PVC impermeable. Motorización con mando a distancia o domótica. Apertura total del techo con canalones invisibles integrados en los perfiles. Ideales para terrazas de restaurantes y hogares en la Costa del Sol.",
      "brand": { "@type": "Brand", "name": "Costa Glass" },
      "offers": {
        "@type": "Offer",
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "url": "https://costaglass.es/retractable-pvc-roof/"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "112"
      }
    },{
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuál es la diferencia entre una pérgola retráctil y una bioclimática?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La retráctil tiene un techo de lona tensada de PVC que se pliega y desaparece por completo, dejando el cielo totalmente abierto. La bioclimática tiene lamas de aluminio que rotan sobre su propio eje, controlando la luz pero sin destapar el techo al 100%."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se puede cerrar por los lados?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, nuestras pérgolas retráctiles están diseñadas para integrarse perfectamente con Cortinas de Cristal, Ventanas de Guillotina o Toldos Zip laterales, creando un cerramiento total."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué mantenimiento necesita la lona?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "La lona de PVC técnica tiene un tratamiento especial anti-moho y anti-rayos UV. Basta con limpiarla ocasionalmente con agua y jabón neutro; no requiere el mantenimiento mecánico complejo de las lamas de aluminio."
          }
        },
        {
          "@type": "Question",
          "name": "¿Es impermeable la pérgola retráctil cuando está cerrada?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí, al 100%. El tejido técnico de PVC de alta tensión es completamente impermeable. Además, los postes de aluminio llevan incorporados canalones invisibles que recogen el agua de lluvia y la evacuan hacia el exterior sin goteos."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se puede motorizar e integrar en domótica?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. El sistema de apertura y cierre de la lona es completamente motorizado, controlable por mando a distancia, app móvil o sistemas de domótica. También es posible añadir sensores de lluvia y viento que cierran la pérgola automáticamente ante condiciones adversas."
          }
        },
        {
          "@type": "Question",
          "name": "¿Se puede incorporar iluminación en la pérgola retráctil?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Sí. Las tiras LED se integran directamente en las vigas transversales de la estructura, proporcionando una iluminación ambiental perfecta para el uso nocturno sin cables visibles ni instalaciones adicionales."
          }
        }
      ]
    }]);
---

<BaseLayout
  title="Pérgolas Retráctiles Motorizadas a Medida | Costa Glass"
  description="Pérgolas retráctiles motorizadas con techo de lona tensada de PVC impermeable al 100%. Techo retráctil motorizado para terrazas de hostelería y hogar en la Costa del Sol. Apertura total del cielo y canalones invisibles. Presupuesto en 24h."
  canonical="https://costaglass.es/retractable-pvc-roof/"
  pageSchema={pageSchema}
>
  <RetractablePvcRoofContent />
</BaseLayout>
